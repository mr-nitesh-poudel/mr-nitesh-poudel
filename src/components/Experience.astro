---
const experiences = [
  {
    role: "Senior Full-Stack Developer",
    company: "Freelance / Independent",
    period: "2022 — Present",
    desc: "Building end-to-end products for clients — iOS apps with SwiftUI, backend APIs with Laravel, and cloud infrastructure on AWS. Specialise in media-heavy apps with complex file processing pipelines.",
    skills: ["Swift", "SwiftUI", "Laravel", "AWS", "PHP"],
  },
  {
    role: "Backend Engineer",
    company: "Tech Startup",
    period: "2020 — 2022",
    desc: "Led the backend architecture for a consumer platform scaling to 50k+ users. Introduced queue-based processing, reduced average API response time by 40%, and migrated file storage to S3.",
    skills: ["Laravel", "MySQL", "Redis", "AWS S3", "Docker"],
  },
  {
    role: "iOS Developer",
    company: "Digital Agency",
    period: "2018 — 2020",
    desc: "Developed and shipped 6 client iOS applications. Introduced modular architecture patterns, a reusable networking layer, and automated UI testing that cut regression time in half.",
    skills: ["Swift", "UIKit", "Objective-C", "CoreData"],
  },
];
---

<section id="experience" class="experience">
  <div class="exp-inner">
    <div class="section-header reveal">
      <span class="section-num">03</span>
      <h2 class="section-title">Experience</h2>
    </div>

    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline-item reveal" style={`transition-delay: ${i * 0.12}s`}>
          <div class="timeline-meta">
            <span class="exp-period">{exp.period}</span>
          </div>
          <div class="timeline-connector" aria-hidden="true">
            <div class="connector-dot"></div>
            <div class="connector-line"></div>
          </div>
          <div class="timeline-content">
            <div class="exp-header">
              <h3 class="exp-role">{exp.role}</h3>
              <span class="exp-company">@ {exp.company}</span>
            </div>
            <p class="exp-desc">{exp.desc}</p>
            <div class="exp-skills">
              {exp.skills.map(s => <span>{s}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 7rem 3rem;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .exp-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 4rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 160px 40px 1fr;
    gap: 0 1rem;
    position: relative;
  }

  .timeline-meta {
    display: flex;
    align-items: flex-start;
    padding-top: 0.2rem;
    justify-content: flex-end;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    white-space: nowrap;
    text-align: right;
  }

  .timeline-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .connector-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--bg-2);
    flex-shrink: 0;
    margin-top: 0.15rem;
    transition: background 0.2s;
  }

  .timeline-item:hover .connector-dot {
    background: var(--accent);
  }

  .connector-line {
    flex: 1;
    width: 1px;
    background: var(--border);
    margin-top: 6px;
    min-height: 40px;
  }

  .timeline-item:last-child .connector-line {
    display: none;
  }

  .timeline-content {
    padding-bottom: 3.5rem;
  }

  .exp-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.85rem;
  }

  .exp-role {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .exp-company {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.03em;
  }

  .exp-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.8;
    max-width: 580px;
    margin-bottom: 1rem;
  }

  .exp-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .exp-skills span {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    padding: 0.2rem 0.55rem;
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text-muted);
  }

  @media (max-width: 700px) {
    .experience {
      padding: 5rem 1.5rem;
    }

    .timeline-item {
      grid-template-columns: 0 28px 1fr;
    }

    .timeline-meta {
      display: none;
    }

    .exp-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
